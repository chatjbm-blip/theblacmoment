rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Contact form submissions — anyone can create, no read/update/delete
    match /contacts/{contactId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'description', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.description is string;
      allow read, update, delete: if false;
    }

    // Newsletter subscriptions — anyone can create, no read/update/delete
    match /subscribers/{subId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'createdAt'])
                    && request.resource.data.email is string;
      allow read, update, delete: if false;
    }

    // Episodes — anyone can read, only auth can write
    match /episodes/{episodeId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Testimonials — anyone can read, only auth can write
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // Guest applications — anyone can create, only auth can read
    match /guests/{guestId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Sponsor applications — anyone can create, only auth can read
    match /sponsors/{sponsorId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Invite requests — anyone can create, only auth can read
    match /invites/{inviteId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Analytics events — anyone can create, only auth can read
    match /analytics/{analyticsId} {
      allow create: if request.resource.data.keys().hasAll(['event', 'timestamp']);
      allow read, update, delete: if isAuth();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
